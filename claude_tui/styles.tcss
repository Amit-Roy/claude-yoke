/* ======================================================================== *
 *  Cockpit — visual identity for the Claude TUI.                            *
 *  Palette mirrors claude_tui/theme.py:                                     *
 *    hull #0F1419  panel #171D24  panel-hi #1E2630  rule #2A323C            *
 *    amber #FFB454  ice #56C7D4  nominal #6FCF97  caution #E5704B           *
 *  Standard $vars (themed by COCKPIT) carry chrome; literal hex carries     *
 *  the bespoke instrument colours so nothing depends on var resolution.     *
 * ======================================================================== */

Screen {
    layout: vertical;
    background: $background;
}

Header {
    background: $panel;
    color: $text-muted;
}

Footer {
    background: $panel;
}

#body {
    height: 1fr;
    layout: horizontal;
}

/* ---- left pane: activity bar -------------------------------------------- */
#activity-bar {
    width: 24;
    background: $panel;
    padding: 1 1;
    border-right: solid #2A323C;
}

#brand {
    text-align: left;
    padding: 0 0 1 0;
    margin-bottom: 1;
    border-bottom: solid #2A323C;
}

.view-button {
    width: 100%;
    height: 3;
    margin-bottom: 1;
    text-align: left;
    border: none;
    border-left: thick transparent;
    background: transparent;
    color: $text-muted;
}

.view-button:hover {
    background: #1E2630;
    color: $text;
}

.view-button.-active {
    background: #2A323C;
    border-left: thick #FFB454;
    color: #FFB454;
    text-style: bold;
}

#activity-bar .spacer {
    height: 1fr;
}

#bar-hint {
    color: $text-muted;
    text-align: left;
}

/* ---- left column: instrument cluster ------------------------------------ */
#left-column {
    width: 1fr;
    layout: vertical;
    min-width: 32;
}

#sidebar-host {
    height: 1fr;
    border-bottom: solid #2A323C;
}

#sessions-header, #files-header {
    padding: 1 1 0 1;
    color: $text-muted;
}

#sessions-listview {
    height: 1fr;
    background: $surface;
}

SessionItem {
    padding: 0 1;
    height: auto;
    border-left: thick transparent;
    border-bottom: solid #202830;
}

SessionItem.-highlight {
    background: #1E2630;
    border-left: thick #FFB454;
}

#claude-dirtree {
    height: 1fr;
    padding: 0 1;
    background: $surface;
}

#tokens-panel {
    height: auto;
    min-height: 10;
    padding: 0 1 1 1;
    border-bottom: solid #2A323C;
    background: $panel;
}

#agents-panel {
    height: 14;
    padding: 0 1 0 1;
    background: $panel;
}

.panel-title, #agents-title {
    color: $text-muted;
    padding-top: 1;
}

#tokens-body {
    padding-top: 1;
}

#agents-table {
    height: 1fr;
    background: $panel;
}

/* ---- right half: the conversation viewport ------------------------------ */
#main {
    width: 1fr;
    layout: vertical;
    min-width: 40;
    border-left: solid #2A323C;
}

#chat-toolbar {
    height: 3;
    padding: 0 1;
    align: left middle;
    border-bottom: solid #2A323C;
}

#chat-toolbar Select {
    width: 18;
    margin-right: 1;
}

#chat-toolbar Button {
    width: auto;
    min-width: 7;
    margin-right: 1;
}

#chat-log {
    height: 1fr;
    padding: 1 1;
    background: $background;
    scrollbar-size-vertical: 1;
}

#composer {
    height: auto;
    padding: 1 1;
    border-top: solid #2A323C;
}

#composer Input {
    width: 1fr;
}

#composer Button {
    width: auto;
    margin-left: 1;
}

/* ---- modal editor ------------------------------------------------------- */
EditorScreen {
    align: center middle;
}

#editor-box {
    width: 84%;
    height: 84%;
    background: $panel;
    border: thick #FFB454;
    padding: 1 2;
}

#editor-title {
    color: $text-muted;
    margin-bottom: 1;
}

#editor-area {
    height: 1fr;
    margin-bottom: 1;
}

#editor-buttons {
    height: auto;
    align: right middle;
}

#editor-buttons Button {
    margin-left: 2;
}

#editor-status {
    height: 1;
}
